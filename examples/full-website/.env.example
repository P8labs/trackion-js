# Trackion Demo Store Configuration
# Copy this file to .env.local and update with your values

# Trackion Server Configuration
VITE_TRACKION_SERVER_URL=http://localhost:8080
VITE_TRACKION_API_KEY=your_api_key_here
VITE_TRACKION_PROJECT_ID=your_project_uuid_here

# Demo User Configuration
VITE_DEMO_USER_ID=demo_user_123

# SDK Configuration
VITE_TRACKION_BATCH_SIZE=10
VITE_TRACKION_FLUSH_INTERVAL=3000
VITE_TRACKION_AUTO_PAGEVIEW=true

# Feature Flags (for documentation - configure these in your Trackion dashboard)
# show_promotion_banner=true
# advanced_testing_features=false  
# experimental_ui=false
# express_checkout=true
# show_analytics_section=true

